# Airtable Integration — create a token at https://airtable.com/create/tokens
# with data.records:write (and scope for your base).
AIRTABLE_API_KEY=
# From your base URL: https://airtable.com/<BASE_ID>/...
AIRTABLE_BASE_ID=appy1wW5Be4OHjvu7
# Table name as shown in Airtable, or table ID (tbl...) from the table URL
AIRTABLE_TABLE_ID=tbl4mx5wt928RCFwg
# Optional if AIRTABLE_TABLE_ID is set (name is ignored when ID is set)
AIRTABLE_TABLE_NAME=

# If the React app is hosted on a different origin than the API, set the API origin (no trailing slash)
# VITE_API_URL=https://your-server.com
