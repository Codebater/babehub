# BabeHub — environment variables template
#
# Copy this file to `.env.local` for local development. On production
# (Coolify on Hetzner, Vercel, Netlify, etc.) paste each value into the
# host's Environment Variables UI. Never commit `.env.local` — it's
# gitignored.
#
# Required for the app to boot: NEXT_PUBLIC_SUPABASE_*. Required for
# actual functionality: NOWPAYMENTS_* + ADMIN_EMAILS. Everything else
# is optional / staged.

# ─── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Project URL + publishable anon key — visible client-side.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only secret. Bypasses RLS. Required by:
#   - /api/nowpayments/ipn webhook (no user session at webhook time)
#   - /auth/callback admin-bootstrap (promoting role to 'admin')
# Get from: Supabase Dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# ─── NOWPayments (REQUIRED for crypto subscriptions / premium) ────────────────
# Sign up at https://account.nowpayments.io.
#   1. Settings → API Keys → create one → paste API key
#   2. Settings → Store Settings → enable IPN; callback URL =
#      https://YOUR-DOMAIN/api/nowpayments/ipn; generate IPN secret
#   3. Settings → Profile → grab public key (store UUID)
# Set SANDBOX=true to test against api.sandbox.nowpayments.io (no real
# crypto moves). Flip to false for production.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_PUBLIC_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# ─── Resend (REQUIRED for email delivery via Supabase Auth) ───────────────────
# Sign up at https://resend.com (free tier 3k emails/day).
#   1. Domains → Add Domain → add SPF + DKIM + DMARC DNS records
#   2. API Keys → create → paste below
#   3. Supabase Dashboard → Authentication → Emails → SMTP Settings:
#        Host=smtp.resend.com  Port=465  Username=resend
#        Password=<this key>   Sender=no-reply@your-domain.com
# Not read by the app code — only here for reference; the integration
# lives inside Supabase, not the app.
RESEND_API_KEY=

# ─── Airtable (OPTIONAL — survey + B2B inquiry mirror) ────────────────────────
# Without these, survey + inquiry forms write only to Supabase (visible
# in the /app/admin/applications + /inquiries dashboard). Set to also
# mirror submissions to an Airtable base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Survey Submissions
AIRTABLE_BANNER_TABLE=B2B Inquiries

# ─── Admin bootstrap (REQUIRED for first admin sign-in) ───────────────────────
# Comma-separated email allow-list. Any user whose email matches gets
# promoted to role='admin' on next sign-in via /auth/callback. Requires
# SUPABASE_SERVICE_ROLE_KEY to be set. After first admin is created you
# can leave this unset; admins manage other admins from /app/admin/users.
ADMIN_EMAILS=you@your-domain.com
